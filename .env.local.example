# Auth
NEXTAUTH_SECRET=                  # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3011
# Production: NEXTAUTH_URL=https://app.roomd.sh  (dashboard host, not roomd.sh)
MARKETING_URL=https://roomd.sh    # sign-out redirect (and marketing links)
AUTH_MODE=apikey                  # apikey | email | both
NEXT_PUBLIC_AUTH_MODE=apikey      # must match AUTH_MODE (login UI reads this)
# ALLOW_OPEN_SIGNUP=true          # only when you intentionally want open OAuth/email signup

# Same Upstash Redis as roomd (or local docker compose on :8079)
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local_dev_token

# roomd backend
ROOMD_URL=http://localhost:3010
# Public MCP URL shown in setup snippets (defaults to ROOMD_URL)
# NEXT_PUBLIC_ROOMD_URL=https://api.roomd.sh
ROOMD_MASTER_KEY=            # must match an OPERATOR_KEYS secret on roomd
                                  # required to provision teams / waitlist invites

# Only needed when AUTH_MODE=email or both
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email invites (nodemailer). Leave blank to disable: invites still work, they
# just show a copyable message instead of sending. Fill these to auto-send.
SMTP_HOST=                        # e.g. smtp.gmail.com or smtp.resend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=                        # Gmail: App Password (not account password)
SMTP_FROM=                        # e.g. "roomd <you@gmail.com>"
SMTP_SECURE=false                 # true for port 465 (TLS on connect)

# ---------------------------------------------------------------------------
# Observability (optional — leave blank locally; set in Vercel for prod)
# ---------------------------------------------------------------------------
# Sentry — create a Next.js project, paste DSN. Auth token only for source maps.
# NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# SENTRY_DSN=                     # same DSN (server); falls back to NEXT_PUBLIC_
# SENTRY_AUTH_TOKEN=              # org token with project:releases + org:read
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_ENVIRONMENT=production

# PostHog — product analytics (browser + server events via track())
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_KEY=                    # optional server-only alias for the same key
